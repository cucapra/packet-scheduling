classes A, B, C, D, E, F, G, H, NEW;

left = strict[(A, 1), (B, 2), (C, 3)];
mid = rr[D, E, F, NEW];
right = rr[G, H];

return wfq[(left, 1), (mid, 2), (right, 3)];

// So we have created:
//              wfq----
//           /    |    \
//         /      |     ----\
//     strict     rr         rr
//     / | \    / | \ \      / \
//    A  B  C  D  E  F NEW  G   H
//
// Compare that to what is in complex_tree:
//              wfq
//           /   |   \
//         /     |     \
//     strict    rr      rr
//     / | \    / | \    / \
//    A  B  C  F  E  D  G   H
//
// We should be able to match up the two trees and identify the point of difference precisely as an "arm added" under the mid rr.
