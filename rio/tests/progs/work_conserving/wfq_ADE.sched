classes A, D, E;

// Compared to wfq_ABC = wfq[(A,2),(B,1),(C,3)], slots 1 and 2 each flip both
// arm AND weight in lockstep: B->D (weight 1->5) and C->E (weight 3->7).
// Exercises the multi-slot lockstep replace path: every diverging slot's
// inner analyze must land on a Replace shape so the meta can ride on the
// trailing ChangeMeta.
policy = wfq[(A, 2), (D, 5), (E, 7)];

return policy
