classes A, B, C, D, E, F, G, H;

// SP arms swapped from A,B,C to C,B,A by re-assigning ranks: C is now
// highest priority, A lowest. Other subtrees identical to complex_tree.
left = strict[(C, 1), (B, 2), (A, 3)];
mid = rr[F, E, D];
right = rr[G, H];

return wfq[(left, 1), (mid, 2), (right, 3)]

//              wfq
//           /   |   \
//         /     |     \
//     strict    rr      rr
//     / | \    / | \    / \
//    C  B  A  F  E  D  G   H
// This is the same tree as complex_tree, but with the SP arms swapped in priority: C is now highest, A is lowest.
